POLYMARKET_AI_ENV=dev
POLYMARKET_AI_DB_URL=sqlite:///data/polymarket_ai.db
POLYMARKET_AI_LOG_LEVEL=INFO
POLYMARKET_AI_DEFAULT_FEE_BPS=150
POLYMARKET_AI_DEFAULT_SLIPPAGE_BPS=50
POLYMARKET_AI_PROVIDER=hud
POLYMARKET_AI_HUD_ENVIRONMENT_NAME=prediction_market_env
POLYMARKET_AI_HUD_BASE_URL=
POLYMARKET_AI_HUD_API_KEY=
POLYMARKET_AI_KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_AI_KALSHI_TRADES_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_AI_MARKET_API_TIMEOUT_SECONDS=10
POLYMARKET_AI_MARKET_DATA_TRADE_LIMIT=100
POLYMARKET_AI_ORCHESTRATOR_MODEL=hud-orchestrator
POLYMARKET_AI_RESEARCH_MODEL=hud-research
POLYMARKET_AI_RULES_MODEL=hud-rules
POLYMARKET_AI_SKEPTIC_MODEL=hud-skeptic
POLYMARKET_AI_PROBABILITY_MODEL=hud-reasoner
POLYMARKET_AI_ALLOW_HEURISTIC_FALLBACK=true
POLYMARKET_AI_FAIL_CLOSED_ON_PROVIDER_ERROR=true
POLYMARKET_AI_OPENAI_BASE_URL=
POLYMARKET_AI_OPENAI_API_KEY=
POLYMARKET_AI_OPENAI_MODEL=gpt-5.4
